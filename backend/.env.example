OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LlamaParse (scripts/parse_badminton_pdf.py)
LLAMA_CLOUD_API_KEY=
# Optional BYOK for multimodal: gemini-2.0-flash -> GOOGLE_API_KEY, openai-gpt-4o-mini -> OPENAI_API_KEY
GOOGLE_API_KEY=
MULTIMODAL_MODEL=gemini-2.0-flash

# Whisper STT (same OpenAI key)
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=ru

MEMORY_AUTH_TOKEN=
DATABASE_URL=sqlite+aiosqlite:///./athletecore.db
GRAPH_CHECKPOINT_PATH=./graph_checkpoints.sqlite

DISABLE_RERANKER=1
RECALL_STABLE_MIN_COS=0.2
RECALL_RANKED_MIN_COS=0.2

PLANNER_MODEL=gpt-4o-mini
ANALYST_MODEL=claude-sonnet-4-20250514
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Qdrant RAG (methodology books in output/*.md)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION_METHODOLOGY=sports_methodology
METHODOLOGY_USE_QDRANT=true
METHODOLOGY_FALLBACK_LEXICAL=true
METHODOLOGY_MIN_SCORE=0.25
METHODOLOGY_CHUNK_TOKENS=900
METHODOLOGY_CHUNK_OVERLAP_TOKENS=120

# Video analysis MVP (pose → metrics → Gemini; video NOT sent to LLM)
VIDEO_STORAGE_DIR=./data/videos
YOLO_POSE_MODEL=yolov8n-pose.pt
YOLO_TRACKER=bytetrack.yaml
VIDEO_FEEDBACK_MODEL=gemini-2.0-flash

# Document upload (chat)
DOCUMENT_STORAGE_DIR=./data/documents
DOCUMENT_GEMINI_MODEL=gemini-2.0-flash
